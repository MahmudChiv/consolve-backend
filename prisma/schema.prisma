// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum UserType {
  SERVICE_PROVIDER
  TRADER
  CUSTOMER
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum BookingType {
  HIRE_NOW
  SCHEDULED
}

model User {
  id             String        @id @default(uuid())
  phoneNumber    String        @unique
  hashedPassword String
  hashedOtp      String?
  otpExpiry      DateTime?
  refreshToken   String?
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  profiles       UserProfile[]
  identities     Identity[]

  @@index([phoneNumber])
}

model UserProfile {
  id                 String           @id @default(uuid())
  userId             String
  firstName          String
  lastName           String
  gender             Gender
  type               UserType
  avatarUrl          String?
  onboardingStatus   OnboardingStatus @default(PENDING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id])
  identity           Identity?
  bookingsAsCustomer Booking[]        @relation("CustomerProfile")
  bookingsAsProvider Booking[]        @relation("ProviderProfile")
  reviewsGiven       Review[]         @relation("ReviewerProfile")
  reviewsReceived    Review[]         @relation("ProviderReviews")

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

model Identity {
  id            String      @id @default(uuid())
  userId        String
  userProfileId String      @unique
  profession    String?
  summary       String?
  /// Array of specialties/skills
  expertise     String[]    @default([])
  /// Years of experience as an integer
  experience    Int?
  /// Availability schedule as JSON
  availability  Json?
  /// Pricing as JSON
  pricing       Json?
  latitude      Float?
  longitude     Float?
  city          String?
  state         String?
  country       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  user          User        @relation(fields: [userId], references: [id])
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])

  @@index([userId])
  @@index([userProfileId])
  @@index([profession])
  @@index([city, state])
  @@index([deletedAt])
}

model Booking {
  id                 String        @id @default(uuid())
  customerId         String
  customerProfileId  String
  providerId         String
  providerProfileId  String
  serviceType        String
  description        String?
  status             BookingStatus @default(PENDING)
  bookingType        BookingType   @default(HIRE_NOW)
  scheduledAt        DateTime?
  priceAgreed        Decimal?      @db.Decimal(12, 2)
  currency           String        @default("NGN")
  locationAddress    String?
  latitude           Float?
  longitude          Float?
  notes              String?
  disputeReason      String?
  disputeDescription String?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customerProfile UserProfile @relation("CustomerProfile", fields: [customerProfileId], references: [id])
  providerProfile UserProfile @relation("ProviderProfile", fields: [providerProfileId], references: [id])
  review          Review?

  @@index([customerId])
  @@index([providerId])
  @@index([customerProfileId])
  @@index([providerProfileId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Review {
  id                String      @id @default(uuid())
  bookingId         String      @unique
  reviewerId        String
  reviewerProfileId String
  providerId        String
  providerProfileId String
  rating            Int
  comment           String?
  createdAt         DateTime    @default(now())

  booking         Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerProfile UserProfile @relation("ReviewerProfile", fields: [reviewerProfileId], references: [id])
  providerProfile UserProfile @relation("ProviderReviews", fields: [providerProfileId], references: [id])

  @@index([providerId])
  @@index([providerProfileId])
  @@map("reviews")
}