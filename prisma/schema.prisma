// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum UserType {
  SERVICE_PROVIDER
  TRADER
  CUSTOMER
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id             String        @id @default(uuid())
  phoneNumber    String        @unique
  hashedPassword String
  hashedOtp      String?
  otpExpiry      DateTime?
  refreshToken   String?
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  profiles       UserProfile[]
  identities     Identity[]

  @@index([phoneNumber])
}

model UserProfile {
  id               String           @id @default(uuid())
  userId           String
  firstName        String
  lastName         String
  gender           Gender
  type             UserType
  avatarUrl        String?
  onboardingStatus OnboardingStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
  identity         Identity?

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

model Identity {
  id            String      @id @default(uuid())
  userId        String
  userProfileId String      @unique
  profession    String?
  summary       String?
  /// Array of specialties/skills (e.g. ["senator wear", "agbada", "ankara"])
  expertise     String[]    @default([])
  /// Years of experience as an integer
  experience    Int?
  /// Availability schedule as JSON { type: "full-time"|"part-time", days?: string }
  availability  Json?
  /// Pricing as JSON { min: number, max: number, currency: "NGN", unit: string, raw: string }
  pricing       Json?
  latitude      Float?
  longitude     Float?
  city          String?
  state         String?
  country       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  user          User        @relation(fields: [userId], references: [id])
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])

  @@index([userId])
  @@index([userProfileId])
  @@index([profession])
  @@index([city, state])
  @@index([deletedAt])
}
