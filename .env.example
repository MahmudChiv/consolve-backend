# Application
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=https://consolve.vercel.app,http://localhost:3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/consolve_db

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Redis
# Use REDIS_URL for managed instances (Railway, Upstash, etc.)
# Fall back to individual vars for local development
REDIS_URL=redis://default:password@host:port
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# OTP
OTP_EXPIRY_SECONDS=600

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# SMTP (Nodemailer — Gmail + App Password)
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Consolve <your.email@gmail.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
